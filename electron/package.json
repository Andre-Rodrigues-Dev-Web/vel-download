{
  "name": "vel-download-electron",
  "version": "1.0.0",
  "description": "Desktop layer do Vel Download",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "wait-on tcp:4000 tcp:5173 && cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:5173 electron .",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "electron": "^37.2.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.3"
  }
}
